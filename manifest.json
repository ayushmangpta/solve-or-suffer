{
  "manifest_version": 3,
  "name": "Solve Or Suffer",
  "version": "1.1",
  "description": "Forces you to solve a random LeetCode problem twice a day by locking your browser.",

  "browser_specific_settings": {
    "gecko": {
      "id": "solve-or-suffer@addon",
      "data_collection_permissions": {
      "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage",
    "alarms",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "logos/logoclean.png"
  },
  "icons": {
    "16": "logos/16logoclean.png",
    "48": "logos/48logoclean.png",
    "128": "logos/128logoclean.png"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/*", "*://www.leetcode.com/*"],
      "css": ["content/content.css"],
      "js": ["content/content.js"]
    }
  ]
}